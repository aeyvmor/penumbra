<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Penumbra.App.App"
             xmlns:local="using:Penumbra.App"
             RequestedThemeVariant="Light">
             <!-- Pinned to Light: the toolbar/canvas use hardcoded light colors, so following a
                  system Dark variant turns control text white and makes the buttons invisible. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>