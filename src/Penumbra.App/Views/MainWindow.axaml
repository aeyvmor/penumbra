<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Penumbra.App.ViewModels"
        xmlns:controls="using:Penumbra.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Penumbra.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960"
        Height="640"
        MinWidth="640"
        MinHeight="420"
        Title="Penumbra">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#E2E6EC"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Undo" Command="{Binding UndoCommand}"/>
                <Button Content="Redo" Command="{Binding RedoCommand}"/>
                <Button Content="Clear" Command="{Binding ClearCommand}"/>
                <ToggleButton Content="Erase"
                              IsChecked="{Binding IsEraseMode}"
                              ToolTip.Tip="Erase whole strokes; one drag is one undo step"/>
                <Border Width="1" Background="#E2E6EC" Margin="4,2"/>
                <Button Content="Recognize" Command="{Binding RecognizeCommand}" FontWeight="SemiBold"/>
                <ToggleButton Content="Live"
                              IsChecked="{Binding LiveRecognition}"
                              ToolTip.Tip="Recognize automatically a beat after pen-lift"/>
                <Border Width="1" Background="#E2E6EC" Margin="4,2"/>
                <Button Content="Save" Click="OnSaveClick"/>
                <Button Content="Open" Click="OnOpenClick"/>
                <TextBlock Text="Left: draw/erase  ·  Pen eraser: automatic  ·  Right/Middle: pan  ·  Wheel: zoom  ·  Tap answer: source ink"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="#5C6673"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="#FFFFFF"
                BorderBrush="#E2E6EC"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <TextBlock Text="{Binding RecognitionText}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#18202A"/>
        </Border>

        <controls:InkCanvasControl x:Name="InkCanvas"
                                   Document="{Binding Document}"
                                   AnswerLayer="{Binding AnswerLayer}"
                                   CausalityRipple="{Binding CausalityRipple}"
                                   IsEraseMode="{Binding IsEraseMode}"
                                   UncertainStrokeIds="{Binding UncertainStrokeIds}"
                                   ProvenanceStrokeIds="{Binding ProvenanceStrokeIds}"/>
    </DockPanel>

</Window>
